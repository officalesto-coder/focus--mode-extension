{
  "manifest_version": 3,
  "name": "Focus Mode",
  "version": "1.0",
  "description": "Hide distracting parts of YouTube.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}